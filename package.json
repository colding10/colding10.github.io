{
  "name": "cold-is-a-dev",
  "type": "module",
  "version": "1.6.2",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --tab-width 4 --use-tabs --write **/*.{ts,css,astro} --ignore-path .gitignore",
    "prettier": "prettier --tab-width 4 --use-tabs --write **/*.{ts,css,astro} --ignore-path .gitignore",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.5",
    "@astrojs/markdown-remark": "6.3.6",
    "@astrojs/mdx": "4.3.4",
    "@astrojs/rss": "4.0.12",
    "@astrojs/sitemap": "3.5.1",
    "@expressive-code/plugin-collapsible-sections": "^0.40.2",
    "@expressive-code/plugin-line-numbers": "^0.40.2",
    "@iconify-json/lucide": "^1.2.73",
    "@tailwindcss/vite": "^4.1.17",
    "astro": "5.13.4",
    "astro-expressive-code": "^0.40.2",
    "astro-icon": "^1.1.5",
    "clsx": "^2.1.1",
    "patch-package": "^8.0.1",
    "rehype-document": "^7.0.3",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.1",
    "remark-emoji": "^5.0.2",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.11",
    "prettier-plugin-tailwindcss": "^0.6.14"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro-organize-imports"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
