---
import '@/styles/global.css'
import '@/styles/typography.css'

import Footer from '@/components/Footer.astro'
import Head from '@/components/Head.astro'
import Header from '@/components/Header.astro'
import { SITE } from '@/consts'
import { cn } from '@/lib/utils'

interface Props {
	class?: string
	decorativeGrid?: boolean
}

const { class: className, decorativeGrid = false } = Astro.props
---

<!doctype html>
<html class="bg-background text-foreground" lang={SITE.locale}>
	<Head>
		<slot name="head" />
	</Head>
	<body>
		<div class="flex min-h-screen flex-col font-mono">
			<div class="sticky top-0 z-40 border-b border-border/30 bg-background [contain:layout_style_paint]">
				<Header />
				<slot name="subposts-navigation" />
				<slot name="table-of-contents" />
			</div>
			<main class="grow py-6">
				<div
					class={cn(
						'mx-auto flex grow flex-col gap-y-6 px-6',
						className,
					)}
				>
					<slot />
				</div>
			</main>
			{
				decorativeGrid && (
					<div
						class="pointer-events-none mx-auto h-24 w-full max-w-3xl select-none px-6"
						aria-hidden="true"
					>
						<div class="dot-grid h-full w-full" />
					</div>
				)
			}
			<Footer />
		</div>
	</body>
</html>
