---
import { cn } from '@/lib/utils'

const icons = {
  info: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
  lightbulb: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`,
  warning: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>`,
  danger: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>`,
  important: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>`,
  book: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>`,
  math: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 4H6l6 8-6 8h12"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`,
  chat: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/></svg>`,
  pencil: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>`,
  checkCircle: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>`,
  list: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>`,
  chevronDown: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>`,
  question: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>`,
  recall: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>`,
  puzzle: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.39 4.39a1 1 0 0 0 .61.93A3 3 0 0 1 18 8a3 3 0 0 1-2 2.68 1 1 0 0 0-.61.93V14a1 1 0 0 1-1 1h-2.39a1 1 0 0 0-.93.61A3 3 0 0 1 8 18a3 3 0 0 1-2.68-2 1 1 0 0 0-.93-.61H2a1 1 0 0 1-1-1V12.39a1 1 0 0 1 .61-.93A3 3 0 0 0 4 8a3 3 0 0 0-2.39-2.68A1 1 0 0 1 1 4.39V2a1 1 0 0 1 1-1h2.39a1 1 0 0 1 .93.61A3 3 0 0 0 8 4a3 3 0 0 0 2.68-2.39A1 1 0 0 1 11.61 1H14a1 1 0 0 1 1 1z"/></svg>`,
  branch: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>`,
  fileText: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><polyline points="14,2 14,8 20,8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10,9 9,9 8,9"/></svg>`,
  anchor: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><circle cx="12" cy="5" r="3"/></svg>`,
  penTool: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.707 21.293a1 1 0 0 1-1.414 0l-1.586-1.586a1 1 0 0 1 0-1.414l5.586-5.586a1 1 0 0 1 1.414 0l1.586 1.586a1 1 0 0 1 0 1.414z"/><path d="m18 13-1.375-6.874a1 1 0 0 0-.746-.776L3.235 2.028a1 1 0 0 0-1.207 1.207L5.35 15.879a1 1 0 0 0 .776.746L13 18"/><path d="m2.3 2.3 7.286 7.286"/><circle cx="11" cy="11" r="2"/></svg>`,
  code: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/></svg>`,
  dumbbell: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 4.5 15 7l2.5 2.5"/><path d="m19.5 2.5 2 2"/><path d="m6.5 19.5 2 2"/><path d="M2 12h20"/><path d="M4.5 17.5 7 15l2.5 2.5"/></svg>`,
  alertCircle: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>`,
} as const

const calloutConfig: Record<string, {
  style: string
  textColor: string
  icon: string
}> = {
  note:        { style: 'bg-blue-500/5 dark:bg-blue-400/10',     textColor: 'text-blue-700 dark:text-blue-300',     icon: icons.info },
  tip:         { style: 'bg-green-500/5 dark:bg-green-400/10',   textColor: 'text-green-700 dark:text-green-300',   icon: icons.lightbulb },
  warning:     { style: 'bg-amber-500/5 dark:bg-amber-400/10',   textColor: 'text-amber-700 dark:text-amber-300',   icon: icons.warning },
  danger:      { style: 'bg-red-500/5 dark:bg-red-400/10',       textColor: 'text-red-700 dark:text-red-300',       icon: icons.danger },
  important:   { style: 'bg-purple-500/5 dark:bg-purple-400/10', textColor: 'text-purple-700 dark:text-purple-300', icon: icons.important },
  definition:  { style: 'bg-purple-500/5 dark:bg-purple-400/10', textColor: 'text-purple-700 dark:text-purple-300', icon: icons.book },
  theorem:     { style: 'bg-teal-500/5 dark:bg-teal-400/10',     textColor: 'text-teal-700 dark:text-teal-300',     icon: icons.math },
  lemma:       { style: 'bg-sky-500/5 dark:bg-sky-400/10',       textColor: 'text-sky-700 dark:text-sky-300',       icon: icons.puzzle },
  proof:       { style: 'bg-gray-500/5 dark:bg-gray-400/10',     textColor: 'text-gray-700 dark:text-gray-300',     icon: icons.check },
  corollary:   { style: 'bg-cyan-500/5 dark:bg-cyan-400/10',     textColor: 'text-cyan-700 dark:text-cyan-300',     icon: icons.branch },
  proposition: { style: 'bg-slate-500/5 dark:bg-slate-400/10',   textColor: 'text-slate-700 dark:text-slate-300',   icon: icons.fileText },
  axiom:       { style: 'bg-violet-500/5 dark:bg-violet-400/10', textColor: 'text-violet-700 dark:text-violet-300', icon: icons.anchor },
  conjecture:  { style: 'bg-pink-500/5 dark:bg-pink-400/10',     textColor: 'text-pink-700 dark:text-pink-300',     icon: icons.question },
  notation:    { style: 'bg-slate-400/5 dark:bg-slate-400/10',   textColor: 'text-slate-700 dark:text-slate-300',   icon: icons.penTool },
  remark:      { style: 'bg-gray-400/5 dark:bg-gray-400/10',     textColor: 'text-gray-700 dark:text-gray-300',     icon: icons.chat },
  intuition:   { style: 'bg-yellow-500/5 dark:bg-yellow-400/10', textColor: 'text-yellow-700 dark:text-yellow-300', icon: icons.lightbulb },
  recall:      { style: 'bg-blue-300/5 dark:bg-blue-400/10',     textColor: 'text-blue-600 dark:text-blue-300',     icon: icons.recall },
  explanation: { style: 'bg-lime-500/5 dark:bg-lime-400/10',     textColor: 'text-lime-700 dark:text-lime-300',     icon: icons.chat },
  example:     { style: 'bg-emerald-500/5 dark:bg-emerald-400/10', textColor: 'text-emerald-700 dark:text-emerald-300', icon: icons.code },
  exercise:    { style: 'bg-indigo-500/5 dark:bg-indigo-400/10', textColor: 'text-indigo-700 dark:text-indigo-300', icon: icons.pencil },
  problem:     { style: 'bg-orange-500/5 dark:bg-orange-400/10', textColor: 'text-orange-700 dark:text-orange-300', icon: icons.alertCircle },
  answer:      { style: 'bg-teal-500/5 dark:bg-teal-400/10',     textColor: 'text-teal-700 dark:text-teal-300',     icon: icons.checkCircle },
  solution:    { style: 'bg-emerald-500/5 dark:bg-emerald-400/10', textColor: 'text-emerald-700 dark:text-emerald-300', icon: icons.checkCircle },
  summary:     { style: 'bg-sky-500/5 dark:bg-sky-400/10',       textColor: 'text-sky-700 dark:text-sky-300',       icon: icons.list },
}

const capitalize = (str: string) => str.charAt(0).toUpperCase() + str.slice(1)

type CalloutVariant = keyof typeof calloutConfig

interface Props {
  title?: string
  class?: string
  variant?: CalloutVariant
  defaultOpen?: boolean
}

const { title, variant = 'note', defaultOpen = true, class: className, ...rest } = Astro.props

const config = calloutConfig[variant] ?? calloutConfig.note
---

<details
  class={cn(
    'relative px-4 py-3 my-6 rounded-md text-sm',
    config.style,
    className,
    '[&[open]>summary_svg:last-child]:rotate-180 [&[open]>summary]:mb-3',
  )}
  {...rest}
  open={defaultOpen}
>
  <summary
    class="flex cursor-pointer items-center font-medium [&::-webkit-details-marker]:hidden"
  >
    <span class={cn('mr-2 size-4 shrink-0 [&>svg]:size-4', config.textColor)} set:html={config.icon} />
    <span class={cn('font-medium mr-2', config.textColor)}>
      {capitalize(variant)}
      {title && <span class="font-normal opacity-70"> ({title})</span>}
    </span>
    <span class={cn('ml-auto size-4 shrink-0 transition-transform duration-200 [&>svg]:size-4', config.textColor)} set:html={icons.chevronDown} />
  </summary>
  <div>
    <slot />
  </div>
</details>
