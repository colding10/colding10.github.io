---
import { cn, getHeadingMargin } from '@/lib/utils'
import type { MarkdownHeading } from 'astro'
import { Icon } from 'astro-icon/components'

type Props = {
	headings: MarkdownHeading[]
}

const { headings } = Astro.props
---

{
	headings && headings.length > 0 && (
		<div id="mobile-toc-container" class="w-full xl:hidden">
			<details class="group">
				<summary class="flex w-full cursor-pointer items-center justify-between">
					<div class="mx-auto flex w-full max-w-3xl items-center px-6 py-3">
						<div class="relative mr-2 size-4">
							<svg class="h-4 w-4" viewBox="0 0 24 24">
								<circle
									class="text-primary/20"
									cx="12"
									cy="12"
									r="10"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
								/>
								<circle
									id="mobile-toc-progress-circle"
									class="text-primary"
									cx="12"
									cy="12"
									r="10"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-dasharray="62.83"
									stroke-dashoffset="62.83"
									transform="rotate(-90 12 12)"
								/>
							</svg>
						</div>
						<span
							id="mobile-toc-current-section"
							class="text-muted-foreground flex-grow truncate text-sm"
						>
							Overview
						</span>
						<span class="text-muted-foreground ml-2">
							<Icon
								name="lucide:chevron-down"
								class="h-4 w-4 transition-transform duration-200 group-open:rotate-180"
							/>
						</span>
					</div>
				</summary>

				<div
					class="mx-auto max-w-3xl overflow-y-auto"
					style="scrollbar-width: thin;"
					data-toc-header-scroll
				>
					<div class="max-h-[30vh]">
						<ul
							class="flex list-none flex-col gap-y-2 px-4 pb-4"
							id="mobile-table-of-contents"
						>
							{headings.map((heading) => (
								<li
									class={cn(
										'px-4 text-sm',
										getHeadingMargin(heading.depth),
										'text-foreground/60',
									)}
								>
									<a
										href={`#${heading.slug}`}
										class="mobile-toc-item block rounded px-2 py-1 underline decoration-transparent underline-offset-[3px] transition-colors duration-200 hover:decoration-inherit"
										data-heading-id={heading.slug}
									>
										{heading.text}
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			</details>
		</div>
	)
}

<script>
	const INITIAL_OVERVIEW_TEXT = 'Overview'
	const HEADER_OFFSET = 102 + 36
	const PROGRESS_CIRCLE_RADIUS = 10
	const PROGRESS_CIRCLE_CIRCUMFERENCE = 2 * Math.PI * PROGRESS_CIRCLE_RADIUS
	const getDocumentHeight = () =>
		Math.max(
			document.body.scrollHeight,
			document.documentElement.scrollHeight,
		)
	const areIdsEqual = (left: string[], right: string[]) =>
		left.length === right.length &&
		left.every((value, index) => value === right[index])

	class MobileTOCState {
		progressCircle: HTMLElement | null = null
		currentSectionText: HTMLElement | null = null
		detailsElement: HTMLDetailsElement | null = null
		listElement: HTMLElement | null = null
		scrollArea: HTMLElement | null = null
		itemById = new Map<string, HTMLElement>()
		headingTextById = new Map<string, string>()
		regions: { id: string; start: number; end: number }[] = []
		activeIds: string[] = []

		reset() {
			this.progressCircle = document.getElementById(
				'mobile-toc-progress-circle',
			)
			this.currentSectionText = document.getElementById(
				'mobile-toc-current-section',
			)
			this.detailsElement = document.querySelector(
				'#mobile-toc-container details',
			)
			this.listElement = document.getElementById(
				'mobile-table-of-contents',
			)
			const tocContainer = document.getElementById('mobile-toc-container')
			this.scrollArea =
				tocContainer?.querySelector('[data-toc-header-scroll]') || null
			this.itemById = new Map(
				Array.from(
					this.listElement?.querySelectorAll<HTMLElement>(
						'.mobile-toc-item',
					) ?? [],
				)
					.map((item) => {
						const id = item.dataset.headingId
						return id ? [id, item] : null
					})
					.filter((entry): entry is [string, HTMLElement] => !!entry),
			)
			this.headingTextById = new Map()
			this.regions = []
			this.activeIds = []

			if (this.progressCircle) {
				this.progressCircle.style.strokeDasharray =
					PROGRESS_CIRCLE_CIRCUMFERENCE.toString()
				this.progressCircle.style.strokeDashoffset =
					PROGRESS_CIRCLE_CIRCUMFERENCE.toString()
			}
		}
	}

	const state = new MobileTOCState()

	class HeadingRegions {
		static build() {
			const headings = Array.from(
				document.querySelectorAll<HTMLElement>(
					'.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6',
				),
			)

			state.headingTextById = new Map(
				headings.map((heading) => [
					heading.id,
					heading.textContent?.trim() ?? '',
				]),
			)

			if (headings.length === 0) {
				state.regions = []
				return
			}

			const documentHeight = getDocumentHeight()

			state.regions = headings.map((heading, index) => {
				const nextHeading = headings[index + 1]
				return {
					id: heading.id,
					start: heading.getBoundingClientRect().top + window.scrollY,
					end: nextHeading
						? nextHeading.getBoundingClientRect().top +
							window.scrollY
						: documentHeight,
				}
			})
		}

		static getVisibleIds(): string[] {
			if (state.regions.length === 0) return []

			const viewportBottom = window.scrollY + window.innerHeight
			const position = window.scrollY + HEADER_OFFSET + 1

			if (position < state.regions[0].start) {
				return state.regions[0].start <= viewportBottom
					? [state.regions[0].id]
					: []
			}

			let left = 0
			let right = state.regions.length - 1
			let currentIndex = right

			while (left <= right) {
				const middle = Math.floor((left + right) / 2)
				if (state.regions[middle].start <= position) {
					currentIndex = middle
					left = middle + 1
				} else {
					right = middle - 1
				}
			}

			return [state.regions[currentIndex].id]
		}
	}

	class TOCHeaderScrollMask {
		static update() {
			if (!state.scrollArea) return

			const { scrollTop, scrollHeight, clientHeight } = state.scrollArea
			const threshold = 5
			const isAtTop = scrollTop <= threshold
			const isAtBottom =
				scrollTop >= scrollHeight - clientHeight - threshold

			state.scrollArea.classList.toggle('mask-t-from-80%', !isAtTop)
			state.scrollArea.classList.toggle('mask-b-from-80%', !isAtBottom)
		}
	}

	class MobileTOCLinks {
		static update(_previousIds: string[], nextIds: string[]) {
			if (!state.listElement || !state.currentSectionText) return

			state.itemById.forEach((item) => {
				item.classList.remove('text-foreground')
				item.removeAttribute('aria-current')
			})

			nextIds.forEach((id) => {
				const activeItem = state.itemById.get(id)
				if (!activeItem) return

				activeItem.classList.add('text-foreground')
				activeItem.setAttribute('aria-current', 'true')
			})

			if (nextIds.length > 0) {
				this.scrollToActive(nextIds[0])
			}

			this.updateCurrentSectionText(nextIds)
		}

		static updateCurrentSectionText(headingIds: string[]) {
			if (!state.currentSectionText) return

			let textToShow = INITIAL_OVERVIEW_TEXT

			if (headingIds.length > 0) {
				const activeTexts = headingIds
					.map((id) => state.headingTextById.get(id))
					.filter((text): text is string => !!text)

				if (activeTexts.length > 0) {
					textToShow = activeTexts.join(', ')
				}
			}

			state.currentSectionText.textContent = textToShow
		}

		static scrollToActive(activeHeadingId: string) {
			const activeItem = state.itemById.get(activeHeadingId)
			if (!activeItem) return

			const scrollContainer = state.scrollArea
			if (!scrollContainer) return

			const { top: containerTop, height: containerHeight } =
				scrollContainer.getBoundingClientRect()
			const { top: itemTop, height: itemHeight } =
				activeItem.getBoundingClientRect()

			const currentItemTop =
				itemTop - containerTop + scrollContainer.scrollTop
			const targetScroll = Math.max(
				0,
				Math.min(
					currentItemTop - (containerHeight - itemHeight) / 2,
					scrollContainer.scrollHeight - scrollContainer.clientHeight,
				),
			)

			if (Math.abs(targetScroll - scrollContainer.scrollTop) > 5) {
				scrollContainer.scrollTop = targetScroll
			}
		}

		static setupInteraction() {
			if (!state.listElement) return

			state.listElement
				.querySelectorAll('.mobile-toc-item')
				.forEach((item) => {
					item.addEventListener('click', () => {
						if (state.detailsElement)
							state.detailsElement.open = false
					})
				})

			if (state.scrollArea) {
				state.scrollArea.addEventListener(
					'scroll',
					() => TOCHeaderScrollMask.update(),
					{ passive: true },
				)
			}

			if (state.detailsElement) {
				state.detailsElement.addEventListener('toggle', () => {
					if (state.detailsElement?.open) {
						setTimeout(TOCHeaderScrollMask.update, 100)
					}
				})
			}
		}
	}

	class ProgressCircle {
		static update() {
			if (!state.progressCircle) return

			const scrollableDistance =
				document.documentElement.scrollHeight - window.innerHeight
			const scrollProgress =
				scrollableDistance > 0
					? Math.min(
							Math.max(window.scrollY / scrollableDistance, 0),
							1,
						)
					: 0

			state.progressCircle.style.strokeDashoffset = (
				PROGRESS_CIRCLE_CIRCUMFERENCE *
				(1 - scrollProgress)
			).toString()
		}
	}

	class MobileTOCController {
		static _ticking = false

		static _onScroll() {
			if (MobileTOCController._ticking) return
			MobileTOCController._ticking = true
			requestAnimationFrame(() => {
				const newActiveIds = HeadingRegions.getVisibleIds()
				if (!areIdsEqual(newActiveIds, state.activeIds)) {
					const previousActiveIds = state.activeIds
					state.activeIds = newActiveIds
					MobileTOCLinks.update(previousActiveIds, newActiveIds)
				}
				ProgressCircle.update()
				MobileTOCController._ticking = false
			})
		}

		static handleResize() {
			HeadingRegions.build()
			MobileTOCController._onScroll()
		}

		static init() {
			state.reset()
			HeadingRegions.build()

			if (!state.currentSectionText) return

			if (state.regions.length === 0) {
				state.currentSectionText.textContent = INITIAL_OVERVIEW_TEXT
				window.addEventListener(
					'scroll',
					MobileTOCController._onScroll,
					{
						passive: true,
					},
				)
				ProgressCircle.update()
				return
			}

			state.activeIds = HeadingRegions.getVisibleIds()
			MobileTOCLinks.update([], state.activeIds)
			ProgressCircle.update()

			MobileTOCLinks.setupInteraction()
			window.addEventListener('scroll', MobileTOCController._onScroll, {
				passive: true,
			})
			window.addEventListener('resize', this.handleResize, {
				passive: true,
			})
		}

		static cleanup() {
			window.removeEventListener('scroll', MobileTOCController._onScroll)
			window.removeEventListener('resize', this.handleResize)
			state.activeIds = []
			state.headingTextById = new Map()
			state.itemById = new Map()
			state.regions = []
		}
	}

	MobileTOCController.init()
	document.addEventListener('astro:after-swap', () => {
		MobileTOCController.cleanup()
		MobileTOCController.init()
	})
	document.addEventListener('astro:before-swap', () =>
		MobileTOCController.cleanup(),
	)
</script>

<style>
	#mobile-table-of-contents [data-heading-id][aria-current='true'] {
		color: var(--foreground);
		background: color-mix(in oklab, var(--accent) 82%, transparent);
		font-weight: 600;
	}
</style>
