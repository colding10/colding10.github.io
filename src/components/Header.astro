---
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { NAV_LINKS, SITE } from '@/consts'
import { Icon } from 'astro-icon/components'
---

<header transition:persist>
	<div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
		<Link href="/" class="flex shrink-0 items-center gap-2.5 font-mono text-lg font-medium tracking-tight transition-opacity duration-200 hover:opacity-70">
			<img src="/static/logo.png" alt="cold" class="size-7 rounded-full object-cover" />
			<span class="hidden min-[300px]:block">{SITE.title}</span>
		</Link>
		<div class="flex items-center gap-6">
			<nav class="hidden items-center gap-6 sm:flex">
				{NAV_LINKS.map((item) => (
					<Link
						href={item.href}
						class="nav-link font-mono text-sm text-muted-foreground transition-colors hover:text-foreground"
					>
						{item.label}
					</Link>
				))}
			</nav>

			<!-- Mobile menu -->
			<details class="relative sm:hidden" id="mobile-nav">
				<summary class="flex cursor-pointer items-center justify-center size-8 rounded-md hover:bg-accent transition-colors list-none [&::-webkit-details-marker]:hidden">
					<Icon name="lucide:menu" class="size-4" />
				</summary>
				<div class="absolute right-0 top-full mt-2 w-40 rounded-md border border-border bg-background p-2 shadow-sm">
					{NAV_LINKS.map((item) => (
						<a
							href={item.href}
							class="block rounded-md px-3 py-2 font-mono text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
						>
							{item.label}
						</a>
					))}
				</div>
			</details>

			<ThemeToggle transition:persist />
		</div>
	</div>
</header>

<script>
	// Close mobile menu when clicking outside or navigating
	document.addEventListener('click', (e) => {
		const details = document.getElementById('mobile-nav') as HTMLDetailsElement
		if (details?.open && !details.contains(e.target as Node)) {
			details.open = false
		}
	})
	document.addEventListener('astro:before-swap', () => {
		const details = document.getElementById('mobile-nav') as HTMLDetailsElement
		if (details) details.open = false
	})
</script>
