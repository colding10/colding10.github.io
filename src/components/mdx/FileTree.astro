---
import { cn } from '@/lib/utils'

interface FileEntry {
	name: string
	highlight?: boolean
	children?: FileEntry[]
}

interface Props {
	title?: string
	entries: FileEntry[]
	class?: string
}

const { title, entries, class: className } = Astro.props

const icons: Record<string, string> = {
	folder: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>`,
	file: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>`,
	code: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
	config: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
	docker: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12.5c-.5-.3-1.7-.6-3-.6-1 0-2 .2-2.8.5-.3-1.4-1.3-2.6-3.2-3.6l-.6-.4-.4.7c-.5.8-.8 2-.6 2.9.1.5.3 1 .6 1.4-.8.5-2.4.7-4.5.7H1.1l-.1.8c0 2.5 1.2 5.6 4 7.4 2.5 1.6 6 2 9.1.7 2.4-1 4.3-2.8 5.5-5.3.7 0 2.3 0 3.1-1.5l.2-.3-.4-.3z"/><rect x="2" y="7" width="2" height="2"/><rect x="5" y="7" width="2" height="2"/><rect x="8" y="7" width="2" height="2"/><rect x="5" y="4" width="2" height="2"/><rect x="11" y="7" width="2" height="2"/></svg>`,
	text: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 13H8"/><path d="M16 17H8"/><path d="M16 13h-2"/></svg>`,
	image: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>`,
	lock: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
}

const codeExts = ['py', 'js', 'ts', 'c', 'cpp', 'h', 'rs', 'go', 'rb', 'java', 'sh', 'sage', 'html', 'css', 'jsx', 'tsx', 'astro', 'mdx', 'php', 'sql']
const configExts = ['json', 'yaml', 'yml', 'toml', 'ini', 'env', 'cfg']
const textExts = ['txt', 'md', 'log', 'csv']
const imageExts = ['png', 'jpg', 'jpeg', 'gif', 'svg', 'webp', 'ico']

function getIcon(name: string, isDir: boolean): string {
	if (isDir) return icons.folder
	const lower = name.toLowerCase()
	if (lower === 'dockerfile' || lower.startsWith('docker-compose')) return icons.docker
	if (lower.includes('flag')) return icons.lock
	if (lower === 'requirements.txt' || lower === 'package.json' || lower === 'cargo.toml') return icons.config
	const ext = lower.split('.').pop() || ''
	if (codeExts.includes(ext)) return icons.code
	if (configExts.includes(ext)) return icons.config
	if (textExts.includes(ext)) return icons.text
	if (imageExts.includes(ext)) return icons.image
	return icons.file
}

function renderEntry(entry: FileEntry, depth: number = 0): string {
	const isDir = entry.children && entry.children.length > 0
	const icon = getIcon(entry.name, !!isDir)
	const hl = entry.highlight
		? ' class="text-foreground font-medium"'
		: ' class="text-muted-foreground"'
	const iconClass = entry.highlight ? 'opacity-60' : 'opacity-35'
	let html = `<div class="flex items-center gap-2 py-0.5" style="padding-left: ${depth * 1.25}rem"${hl}><span class="shrink-0 ${iconClass}">${icon}</span><span>${entry.name}</span></div>`
	if (isDir && entry.children) {
		for (const child of entry.children) {
			html += renderEntry(child, depth + 1)
		}
	}
	return html
}

let treeHtml = ''
for (const entry of entries) {
	treeHtml += renderEntry(entry)
}
---

<div class={cn('not-prose my-6 rounded-md bg-secondary/40 p-4 text-sm font-mono', className)}>
	{title && <div class="mb-3 text-xs font-medium uppercase tracking-wider text-muted-foreground">{title}</div>}
	<div set:html={treeHtml} />
</div>
