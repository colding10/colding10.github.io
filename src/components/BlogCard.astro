---
import {
  getCombinedReadingTime,
  getSubpostCount,
  isSubpost,
  parseAuthors,
} from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import Link from './Link.astro'

interface Props {
  entry: CollectionEntry<'blog'>
  variant?: 'list' | 'card'
}

const { entry, variant = 'list' } = Astro.props
const formattedDate = formatDate(entry.data.date)
const readTime = await getCombinedReadingTime(entry.id)
const authors = await parseAuthors(entry.data.authors ?? [])
const subpostCount = !isSubpost(entry.id) ? await getSubpostCount(entry.id) : 0
---

{
  variant === 'card' ? (
    <div class="group/card h-full">
      <Link
        href={`/${entry.collection}/${entry.id}`}
        class="border-border/60 bg-background/75 hover:border-border block h-full rounded-2xl border p-4 transition-[transform,border-color,box-shadow,background-color] duration-200 hover:-translate-y-0.5 hover:shadow-sm"
      >
        <div class="flex h-full flex-col">
          {entry.data.image && (
            <div class="border-border/50 bg-muted/25 mb-4 overflow-hidden rounded-xl border">
              <Image
                src={entry.data.image}
                alt={entry.data.title}
                width={1200}
                height={630}
                class="aspect-[4/3] w-full object-cover transition-transform duration-300 group-hover/card:scale-[1.02]"
              />
            </div>
          )}

          <div class="text-muted-foreground mb-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-[11px] tracking-[0.18em] uppercase">
            <span>{formattedDate}</span>
            <span class="opacity-35">&middot;</span>
            <span>{readTime}</span>
            {subpostCount > 0 && (
              <>
                <span class="opacity-35">&middot;</span>
                <span>
                  {subpostCount} subpost{subpostCount === 1 ? '' : 's'}
                </span>
              </>
            )}
          </div>

          <h3 class="group-hover/card:text-primary mb-2 min-h-[3.5rem] font-serif text-2xl leading-tight font-bold transition-colors duration-200">
            {entry.data.title}
          </h3>

          {entry.data.description && (
            <p class="text-muted-foreground mb-4 line-clamp-2 min-h-[2.75rem] text-sm leading-relaxed">
              {entry.data.description}
            </p>
          )}

          {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="border-border/40 text-muted-foreground mt-auto border-t pt-4 text-[11px]">
              <div class="flex flex-wrap gap-2">
                {entry.data.tags.slice(0, 2).map((tag) => (
                  <span class="border-border/50 bg-muted/25 rounded-full border px-2.5 py-1">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      </Link>
    </div>
  ) : (
    <div class="group/list hover:bg-accent/40 -mx-4 rounded-lg px-4 py-3 transition-colors duration-200">
      <Link
        href={`/${entry.collection}/${entry.id}`}
        class="flex flex-col gap-4 sm:flex-row"
      >
        {entry.data.image && (
          <div class="max-w-3xs sm:shrink-0">
            <Image
              src={entry.data.image}
              alt={entry.data.title}
              width={1200}
              height={630}
              class="object-cover"
            />
          </div>
        )}

        <div class="grow">
          <h3 class="group-hover/list:text-primary mb-1 font-serif text-lg font-bold transition-colors duration-200">
            {entry.data.title}
          </h3>
          <p class="text-muted-foreground mb-2 text-sm">
            {entry.data.description}
          </p>

          <div class="text-muted-foreground mb-2 flex flex-wrap items-center gap-x-2 text-xs">
            {authors.length > 0 && (
              <>
                {authors.map((author) => (
                  <div class="flex items-center gap-x-1.5">
                    <img
                      src={author.avatar}
                      alt={author.name}
                      class="size-5 rounded-full"
                      loading="lazy"
                      decoding="async"
                    />
                    <span>{author.name}</span>
                  </div>
                ))}
                <span class="opacity-30">&middot;</span>
              </>
            )}
            <span>{formattedDate}</span>
            {subpostCount > 0 && (
              <>
                <span class="opacity-30">&middot;</span>
                <span class="flex items-center gap-1">
                  <Icon name="lucide:file-text" class="size-3" />
                  {subpostCount} subpost
                  {subpostCount === 1 ? '' : 's'}
                </span>
              </>
            )}
          </div>

          {entry.data.tags && (
            <div class="text-muted-foreground flex flex-wrap gap-x-2 text-xs">
              {entry.data.tags.map((tag) => (
                <span class="opacity-60">#{tag}</span>
              ))}
            </div>
          )}
        </div>
      </Link>
    </div>
  )
}
