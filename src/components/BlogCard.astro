---
import {
	getCombinedReadingTime,
	getSubpostCount,
	isSubpost,
	parseAuthors,
} from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import Link from './Link.astro'

interface Props {
	entry: CollectionEntry<'blog'>
	variant?: 'list' | 'card'
}

const { entry, variant = 'list' } = Astro.props
const formattedDate = formatDate(entry.data.date)
const readTime = await getCombinedReadingTime(entry.id)
const authors = await parseAuthors(entry.data.authors ?? [])
const subpostCount = !isSubpost(entry.id) ? await getSubpostCount(entry.id) : 0
---

{
	variant === 'card' ? (
		<div class="group/card">
			<Link
				href={`/${entry.collection}/${entry.id}`}
				class="block"
			>
				{entry.data.image && (
					<div class="mb-4 overflow-hidden rounded-lg">
						<Image
							src={entry.data.image}
							alt={entry.data.title}
							width={400}
							height={400}
							class="size-20 rounded-lg object-cover"
						/>
					</div>
				)}
				<h3 class="mb-2 font-serif text-lg font-bold leading-snug transition-colors duration-200 group-hover/card:text-primary">
					{entry.data.title}
				</h3>
				<p class="text-muted-foreground mb-3 text-xs">
					{formattedDate}
				</p>
				{entry.data.tags && (
					<div class="text-muted-foreground flex flex-wrap gap-x-2 text-xs">
						{entry.data.tags.map((tag) => (
							<span class="opacity-60">#{tag}</span>
						))}
					</div>
				)}
			</Link>
		</div>
	) : (
		<div class="group/list -mx-4 rounded-lg px-4 py-3 transition-colors duration-200 hover:bg-accent/40">
			<Link
				href={`/${entry.collection}/${entry.id}`}
				class="flex flex-col gap-4 sm:flex-row"
			>
				{entry.data.image && (
					<div class="max-w-3xs sm:shrink-0">
						<Image
							src={entry.data.image}
							alt={entry.data.title}
							width={1200}
							height={630}
							class="object-cover"
						/>
					</div>
				)}

				<div class="grow">
					<h3 class="mb-1 font-serif text-lg font-bold transition-colors duration-200 group-hover/list:text-primary">{entry.data.title}</h3>
					<p class="text-muted-foreground mb-2 text-sm">
						{entry.data.description}
					</p>

					<div class="text-muted-foreground mb-2 flex flex-wrap items-center gap-x-2 text-xs">
						{authors.length > 0 && (
							<>
								{authors.map((author) => (
									<div class="flex items-center gap-x-1.5">
										<img
											src={author.avatar}
											alt={author.name}
											class="size-5 rounded-full"
											loading="lazy"
											decoding="async"
										/>
										<span>{author.name}</span>
									</div>
								))}
								<span class="opacity-30">&middot;</span>
							</>
						)}
						<span>{formattedDate}</span>
						{subpostCount > 0 && (
							<>
								<span class="opacity-30">&middot;</span>
								<span class="flex items-center gap-1">
									<Icon name="lucide:file-text" class="size-3" />
									{subpostCount} subpost
									{subpostCount === 1 ? '' : 's'}
								</span>
							</>
						)}
					</div>

					{entry.data.tags && (
						<div class="text-muted-foreground flex flex-wrap gap-x-2 text-xs">
							{entry.data.tags.map((tag) => (
								<span class="opacity-60">#{tag}</span>
							))}
						</div>
					)}
				</div>
			</Link>
		</div>
	)
}
