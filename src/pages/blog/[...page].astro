---
import BlogCard from '@/components/BlogCard.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import { SITE } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getAllPosts, groupPostsByYear } from '@/lib/data-utils'
import type { PaginateFunction } from 'astro'

export async function getStaticPaths({
	paginate,
}: {
	paginate: PaginateFunction
}) {
	const allPosts = await getAllPosts()
	return paginate(allPosts, { pageSize: SITE.postsPerPage })
}

const { page } = Astro.props

const postsByYear = groupPostsByYear(page.data)
const years = Object.keys(postsByYear).sort((a, b) => parseInt(b) - parseInt(a))
---

<Layout class="max-w-3xl">
	<PageHead slot="head" title="Blog" />
	<Breadcrumbs
		items={[
			{ label: 'Blog', href: '/blog', icon: 'lucide:library-big' },
			{ label: `Page ${page.currentPage}`, icon: 'lucide:book-copy' },
		]}
	/>

	<div class="flex flex-col gap-y-8">
		{
			years.map((year) => (
				<section class="flex flex-col gap-y-4">
					<div class="font-serif text-xl font-bold">{year}</div>
					<ul class="flex flex-col gap-4">
						{postsByYear[year].map((post) => (
							<li>
								<BlogCard entry={post} />
							</li>
						))}
					</ul>
				</section>
			))
		}
	</div>

	{page.lastPage > 1 && (
		<nav class="flex items-center justify-center gap-1 pt-8" aria-label="Pagination">
			{page.currentPage > 1 && (
				<a
					href={page.currentPage === 2 ? '/blog/' : `/blog/${page.currentPage - 1}`}
					class="inline-flex items-center justify-center size-9 rounded-md border border-border bg-background text-sm hover:bg-accent hover:text-accent-foreground transition-colors"
					aria-label="Previous page"
				>
					&larr;
				</a>
			)}
			{Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
				<a
					href={pageNum === 1 ? '/blog/' : `/blog/${pageNum}`}
					class={pageNum === page.currentPage
						? "inline-flex items-center justify-center size-9 rounded-md bg-primary text-primary-foreground text-sm font-medium"
						: "inline-flex items-center justify-center size-9 rounded-md border border-border bg-background text-sm hover:bg-accent hover:text-accent-foreground transition-colors"
					}
					aria-current={pageNum === page.currentPage ? "page" : undefined}
				>
					{pageNum}
				</a>
			))}
			{page.currentPage < page.lastPage && (
				<a
					href={`/blog/${page.currentPage + 1}`}
					class="inline-flex items-center justify-center size-9 rounded-md border border-border bg-background text-sm hover:bg-accent hover:text-accent-foreground transition-colors"
					aria-label="Next page"
				>
					&rarr;
				</a>
			)}
		</nav>
	)}
</Layout>
