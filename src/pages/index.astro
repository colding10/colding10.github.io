---
import BlogCard from '@/components/BlogCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { SITE } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getRecentPosts } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
const latestPost = blog[0]
---

<Layout class="max-w-3xl" decorativeGrid>
  <PageHead slot="head" title="Home" />

  <section
    class="mt-6 mb-12 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(16rem,0.78fr)] lg:items-start"
  >
    <div>
      <h1
        class="mb-4 font-serif text-5xl leading-none font-bold tracking-tight sm:text-6xl lg:text-[4.75rem]"
      >
        Hi, I'm cold
      </h1>
      <p
        class="text-muted-foreground mb-5 text-xs font-semibold tracking-[0.28em] uppercase"
      >
        AI Believer / CTF Player
      </p>
      <p class="text-muted-foreground max-w-2xl text-base leading-relaxed">
        This is my site where I'll put blog posts, things I learn, and other
        random stuff. Some of it is <Link
          href="https://en.wikipedia.org/wiki/Capture_the_flag_(cybersecurity)"
          class="text-foreground hover:text-primary underline transition-colors"
          external>CTF</Link
        >, some of it is not. Hopefully you can learn something here.
      </p>
    </div>

    <div
      class="border-border/60 bg-background/70 rounded-2xl border shadow-xs lg:mt-10"
    >
      <div class="divide-border/40 divide-y">
        <Link
          href={`/blog/${latestPost.id}`}
          class="group hover:bg-accent/30 block px-5 py-4 transition-colors duration-200"
        >
          <p
            class="text-muted-foreground mb-1 text-[11px] font-semibold tracking-[0.18em] uppercase"
          >
            Latest Post
          </p>
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm leading-relaxed">
                {latestPost.data.title}
              </p>
              <p class="text-muted-foreground mt-1 text-xs">
                {
                  latestPost.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric',
                  })
                }
              </p>
            </div>
            <span
              class="text-muted-foreground inline-block pt-0.5 transition-transform duration-200 group-hover:translate-x-0.5"
              aria-hidden="true">&rarr;</span
            >
          </div>
        </Link>

        <Link
          href="/blog"
          class="group hover:bg-accent/30 block px-5 py-4 transition-colors duration-200"
        >
          <p
            class="text-muted-foreground mb-1 text-[11px] font-semibold tracking-[0.18em] uppercase"
          >
            All Posts
          </p>
          <div class="flex items-start justify-between gap-3">
            <p class="text-sm leading-relaxed">
              Archive of blog posts, writeups, and notes.
            </p>
            <span
              class="text-muted-foreground inline-block pt-0.5 transition-transform duration-200 group-hover:translate-x-0.5"
              aria-hidden="true">&rarr;</span
            >
          </div>
        </Link>

        <Link
          href="/history"
          class="group hover:bg-accent/30 block px-5 py-4 transition-colors duration-200"
        >
          <p
            class="text-muted-foreground mb-1 text-[11px] font-semibold tracking-[0.18em] uppercase"
          >
            CTF History
          </p>
          <div class="flex items-start justify-between gap-3">
            <p class="text-sm leading-relaxed">
              Competitions, teams, placements, and timeline.
            </p>
            <span
              class="text-muted-foreground inline-block pt-0.5 transition-transform duration-200 group-hover:translate-x-0.5"
              aria-hidden="true">&rarr;</span
            >
          </div>
        </Link>
      </div>
    </div>
  </section>

  <section class="space-y-7">
    <div class="flex items-center justify-between">
      <h2 class="font-serif text-3xl font-bold">Latest Posts</h2>
      <Link
        href="/blog"
        class="text-muted-foreground hover:text-foreground group inline-flex items-center gap-1.5 text-sm transition-colors duration-200"
      >
        View all
        <span
          class="inline-block transition-transform duration-200 group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
      {blog.map((post) => <BlogCard entry={post} variant="card" />)}
    </div>
  </section>
</Layout>
