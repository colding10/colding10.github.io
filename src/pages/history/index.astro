---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import {
	getTierBadgeClasses,
	getTierFromRank,
	MONTHS,
	parsePlacementNumber,
} from '@/lib/history-utils'
import { TEAM_URLS } from '@/lib/team-utils'
import { getCollection } from 'astro:content'

const ctfCollection = await getCollection('ctfs')
const entries = ctfCollection.map((entry) => ({ id: entry.id, ...entry.data }))

type Group = { year: number; month: number; items: typeof entries }

const sorted = [...entries].sort((a, b) => b.year - a.year || b.month - a.month)

const groupsMap = new Map<string, Group>()
for (const e of sorted) {
	const key = `${e.year}-${String(e.month).padStart(2, '0')}`
	if (!groupsMap.has(key))
		groupsMap.set(key, { year: e.year, month: e.month, items: [] })
	groupsMap.get(key)!.items.push(e)
}
const groups = Array.from(groupsMap.values()).sort(
	(a, b) => b.year - a.year || b.month - a.month,
)

const totalCTFs = entries.length
const uniqueMonthsSet = new Set(entries.map((e) => `${e.year}-${e.month}`))
const totalMonths = uniqueMonthsSet.size

// Get unique years and teams for filters
const uniqueYears = Array.from(new Set(entries.map((e) => e.year))).sort(
	(a, b) => b - a,
)
const uniqueTeams = Array.from(
	new Set(entries.filter((e) => e.team).map((e) => e.team)),
).sort()
---

<Layout class="max-w-3xl">
	<PageHead
		slot="head"
		title="CTF History"
		description="Timeline of CTF competitions and results"
	/>
	<Breadcrumbs items={[{ label: 'History', icon: 'lucide:calendar' }]} />

	<section aria-labelledby="ctf-history-title" class="font-mono">
		<div class="mt-5">
			<h1 id="ctf-history-title" class="font-serif text-3xl font-bold">
				CTF History
			</h1>
			<p class="text-muted-foreground mt-2">
				Competition results over time, newest first.
			</p>
		</div>

		<div class="mt-4 space-y-4">
			<div class="text-muted-foreground flex flex-wrap gap-x-6 gap-y-1 text-sm">
				<div>
					<span>Total CTFs:</span>
					<span class="text-foreground ml-1 font-semibold">{totalCTFs}</span>
				</div>
				<div>
					<span>Months Active:</span>
					<span class="text-foreground ml-1 font-semibold">{totalMonths}</span>
				</div>
				<div>
					Teams: {
						Object.entries(TEAM_URLS).map(
							([team, url], index) => (
								<>
									<a
										href={url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-foreground font-mono transition-colors duration-200 hover:underline"
									>
										{team}
									</a>
									{index <
										Object.keys(TEAM_URLS).length - 1 &&
										', '}
								</>
							),
						)
					}
				</div>
			</div>

			<div class="text-muted-foreground text-xs">
				Sorted by month/year. Use query operators like
				<code>year:2025</code>, <code>team:BCA</code>,
				<code>tier:A</code>, or <code>top:10</code>.
			</div>

			<!-- Search and Filter -->
			<div class="space-y-3">
				<div
					class="flex flex-col gap-2 sm:flex-row sm:items-center"
				>
					<input
						type="text"
						id="search"
						placeholder="Search CTF names..."
						class="bg-background placeholder:text-muted-foreground focus:ring-ring hover:border-muted-foreground/30 flex-1 rounded-md border border-border/50 px-3 py-2 text-sm transition-colors duration-200 focus:ring-2 focus:outline-none"
					/>

					<div class="flex flex-wrap gap-2">
						<select id="yearFilter" class="bg-background border border-border/50 rounded-md px-3 py-2 text-sm transition-colors focus:ring-2 focus:ring-ring focus:outline-none">
							<option value="">All Years</option>
							{uniqueYears.map((year) => <option value={year}>{year}</option>)}
						</select>
						<select id="tierFilter" class="bg-background border border-border/50 rounded-md px-3 py-2 text-sm transition-colors focus:ring-2 focus:ring-ring focus:outline-none">
							<option value="">All Placements</option>
							<option value="SS">SS</option>
							<option value="S">S</option>
							<option value="A">A</option>
							<option value="B">B</option>
							<option value="C">C</option>
							<option value="D">D</option>
							<option value="TOP10">Top 10</option>
							<option value="TOP5">Top 5</option>
							<option value="TOP3">Top 3</option>
						</select>
						<select id="teamFilter" class="bg-background border border-border/50 rounded-md px-3 py-2 text-sm transition-colors focus:ring-2 focus:ring-ring focus:outline-none">
							<option value="">All Teams</option>
							{uniqueTeams.map((team) => <option value={team}>{team}</option>)}
						</select>
					</div>
				</div>
				<div
					class="text-muted-foreground flex items-center gap-2 text-xs"
				>
					<span id="resultCount">{entries.length} CTFs</span>
					<span>&middot;</span>
					<button
						id="clearFilters"
						class="hover:text-foreground underline transition-colors duration-200"
					>
						Clear filters
					</button>
				</div>
				<div
					id="teamHelper"
					class="text-muted-foreground hidden text-xs"
				>
					Names with spaces: use quotes or parentheses, e.g.
					<code>team:&quot;Cosmic Squid&quot;</code> or <code
						>team:(Cosmic Squid)</code
					>.
				</div>
			</div>
		</div>

		<div class="mt-8">
			<div class="space-y-10">
				{
					groups.map((group) => (
						<div
							class="month-group transition-opacity duration-300"
							data-month={group.month}
							data-year={group.year}
						>
							<p class="text-muted-foreground mb-4 text-xs font-medium tracking-wider uppercase">
								{MONTHS[group.month - 1]} {group.year}
							</p>

							<ul class="space-y-2.5">
								{group.items.map((e) => {
									const rank = parsePlacementNumber(
										e.placement,
									)
									const tier = getTierFromRank(rank)
									return (
										<li
											class="timeline-item transition-colors duration-200"
											data-name={e.name}
											data-year={e.year}
											data-team={e.team || ''}
											data-rank={rank ?? ''}
											data-tier={tier}
										>
											<div class="flex items-start gap-2">
												<span
													class={`mt-0.5 inline-flex h-5 min-w-[1.25rem] items-center justify-center rounded text-[10px] font-bold ${getTierBadgeClasses(tier)}`}
												>
													{tier}
												</span>
												<div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
													<a
														href={`/history/${encodeURIComponent(e.id)}`}
														class="text-primary font-medium transition-colors duration-200 hover:underline"
													>
														{e.name}
													</a>

													<span class="text-muted-foreground text-sm">
														{e.placement}
													</span>

													{e.team && (
														<span class="text-muted-foreground text-xs">
															{e.team}
														</span>
													)}

													{e.description && (
														<span class="text-muted-foreground text-sm italic opacity-60">
															— {e.description}
														</span>
													)}
												</div>
											</div>
										</li>
									)
								})}
							</ul>
						</div>
					))
				}
			</div>

			{
				groups.length === 0 && (
					<div class="py-12 text-center">
						<p class="text-muted-foreground">
							No CTF entries yet. Add some to the entries array!
						</p>
					</div>
				)
			}
		</div>
	</section>
</Layout>

<script>
	// Search and filter functionality
	const searchInput = document.getElementById('search') as HTMLInputElement
	const clearFilters = document.getElementById(
		'clearFilters',
	) as HTMLButtonElement
	const resultCount = document.getElementById(
		'resultCount',
	) as HTMLSpanElement
	const timelineItems = document.querySelectorAll('.timeline-item')
	const monthGroups = document.querySelectorAll('.month-group')
	const teamHelper = document.getElementById('teamHelper') as HTMLDivElement

	// Filter state
	let selectedYear = ''
	let selectedTeam = ''
	let selectedTier = ''

	const yearSelect = document.getElementById('yearFilter') as HTMLSelectElement
	const tierSelect = document.getElementById('tierFilter') as HTMLSelectElement
	const teamSelect = document.getElementById('teamFilter') as HTMLSelectElement

	yearSelect?.addEventListener('change', () => {
		selectedYear = yearSelect.value
		filterItems()
	})

	tierSelect?.addEventListener('change', () => {
		selectedTier = tierSelect.value
		filterItems()
	})

	teamSelect?.addEventListener('change', () => {
		selectedTeam = teamSelect.value
		filterItems()
	})

	function parseQuery(raw: string) {
		const text = raw.trim()
		const tokens = []
		const re = /(year|team|tier|top):("[^"]+"|'[^']+'|\([^\)]*\)|\S+)/gi
		let match
		while ((match = re.exec(text)) !== null) {
			tokens.push({ key: match[1].toLowerCase(), value: match[2] })
		}

		// Remove tokens from free text
		const cleaned = text
			.replace(re, '')
			.replace(/\s{2,}/g, ' ')
			.trim()

		const result = {
			search: cleaned,
			year: '',
			team: '',
			tier: '',
			top: '',
		}
		for (const t of tokens) {
			let val = t.value
			if (
				(val.startsWith('"') && val.endsWith('"')) ||
				(val.startsWith("'") && val.endsWith("'")) ||
				(val.startsWith('(') && val.endsWith(')'))
			) {
				val = val.slice(1, -1)
			}
			if (t.key === 'year') result.year = val
			if (t.key === 'team') result.team = val
			if (t.key === 'tier') result.tier = val.toUpperCase()
			if (t.key === 'top') result.top = val
		}
		return result
	}

	function filterItems() {
		const parsed = parseQuery(searchInput.value)
		const searchTerm = parsed.search.toLowerCase()

		// Operators override dropdowns if provided
		const effectiveYear = parsed.year || selectedYear
		const effectiveTeam = parsed.team || selectedTeam
		const effectiveTier = parsed.tier || selectedTier
		const effectiveTop = parsed.top

		let visibleCount = 0

		// First, filter individual items
		timelineItems.forEach((item) => {
			const name = item.getAttribute('data-name')?.toLowerCase() || ''
			const year = item.getAttribute('data-year') || ''
			const team = item.getAttribute('data-team') || ''
			const rankStr = item.getAttribute('data-rank') || ''
			const tier = item.getAttribute('data-tier') || ''

			const matchesSearch = name.includes(searchTerm)
			const matchesYear = !effectiveYear || year === effectiveYear
			const matchesTeam = !effectiveTeam || team === effectiveTeam

			let matchesTier = true
			const topNum = effectiveTop ? Number(effectiveTop) : NaN
			if (effectiveTier) {
				if (
					['SS', 'S', 'A', 'B', 'C', 'D', 'F'].includes(effectiveTier)
				) {
					matchesTier = tier === effectiveTier
				} else if (effectiveTier === 'TOP3') {
					matchesTier =
						!!rankStr && Number(rankStr) > 0 && Number(rankStr) <= 3
				} else if (effectiveTier === 'TOP5') {
					matchesTier =
						!!rankStr && Number(rankStr) > 0 && Number(rankStr) <= 5
				} else if (effectiveTier === 'TOP10') {
					matchesTier =
						!!rankStr &&
						Number(rankStr) > 0 &&
						Number(rankStr) <= 10
				}
			}
			if (!Number.isNaN(topNum) && topNum > 0) {
				matchesTier =
					matchesTier &&
					!!rankStr &&
					Number(rankStr) > 0 &&
					Number(rankStr) <= topNum
			}

			if (matchesSearch && matchesYear && matchesTeam && matchesTier) {
				item.classList.remove('hidden')
				visibleCount++
			} else {
				item.classList.add('hidden')
			}
		})

		// Then, hide/show month groups based on whether they have visible items
		monthGroups.forEach((group) => {
			const visibleItemsInGroup = group.querySelectorAll(
				'.timeline-item:not(.hidden)',
			)
			if (visibleItemsInGroup.length === 0) {
				group.classList.add('hidden')
			} else {
				group.classList.remove('hidden')
			}
		})

		resultCount.textContent = `${visibleCount} CTF${visibleCount !== 1 ? 's' : ''}`

		// Toggle helper visibility when query includes team:
		if (/\bteam:\s*/i.test(searchInput.value)) {
			teamHelper?.classList.remove('hidden')
		} else {
			teamHelper?.classList.add('hidden')
		}
	}

	function clearAllFilters() {
		searchInput.value = ''
		selectedYear = ''
		selectedTeam = ''
		selectedTier = ''
		if (yearSelect) yearSelect.value = ''
		if (tierSelect) tierSelect.value = ''
		if (teamSelect) teamSelect.value = ''
		filterItems()
	}

	searchInput.addEventListener('input', filterItems)
	clearFilters.addEventListener('click', clearAllFilters)
</script>
